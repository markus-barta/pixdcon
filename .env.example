# pixdcon environment variables
# In production: injected via agenix at /run/agenix/hsb1-pixdcon-env

# MQTT broker — must match MOSQUITTO_* naming from agenix secret
MOSQUITTO_HOST=localhost
MOSQUITTO_USER=smarthome
MOSQUITTO_PASS=<your-mqtt-password>

# Sonnenbatterie direct API (faster than HA MQTT, polled every 3s)
SONNEN_BATTERY_HOST=192.168.1.32
SONNEN_BATTERY_API_TOKEN=<your-sonnen-api-token>

# Non-secret config (set directly in docker-compose environment:)
MQTT_PORT=1883
LOG_LEVEL=info
TZ=Europe/Vienna
PIXDCON_CONFIG_PATH=/data/config.json
