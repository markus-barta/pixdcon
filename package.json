{
  "name": "pidicon-light",
  "version": "2.0.0",
  "description": "Minimalist pixel display controller - config-file driven, web UI",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint .",
